{
    "version": 2,
    "configurePresets": [
        {
            "name": "win-base",
            "inherits": "vcpkg-base",
            "hidden": true,
            "environment": {
                "VCPKG_ROOT": "<your path to vcpkg>"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            }
        },
        {
            "name": "win32-rel",
            "inherits": "win-base",
            "architecture": {
                "value": "x86",
                "strategy": "external"
            },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-windows-static",
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "win64-rel",
            "inherits": "win-base",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows-static",
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "android-base",
            "inherits": "vcpkg-android-base",
            "hidden": true,
            "environment": {
                "VCPKG_ROOT": "<your path to vcpkg>",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cpp-ext/cmake/vcpkg-triplets",
                "ANDROID_SDK_PATH": "<your path to android sdk>",
                "NDK_VERSION": "27.0.12077973"
            }
        },
        {
            "name": "android-arm64-v8a",
            "inherits": "android-base",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "arm64-android-api23",
                "CMAKE_ANDROID_ARCH_ABI":"arm64-v8a"
            }
        },
        {
            "name": "android-armeabi-v7a",
            "inherits": "android-base",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "arm-android-api23",
                "CMAKE_ANDROID_ARCH_ABI":"armeabi-v7a"
            }
        },
        {
            "name": "android-x86",
            "inherits": "android-base",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-android-api23",
                "CMAKE_ANDROID_ARCH_ABI":"x86"
            }
        },
        {
            "name": "android-x86-64",
            "inherits": "android-base",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-android-api23",
                "CMAKE_ANDROID_ARCH_ABI":"x86_64"
            }
        }
    ]
}